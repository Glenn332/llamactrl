{
  "LlamaCtrl": {
    "Port": 3131,
    "DataDir": "~/.config/llamactrl",
    "ModelsDir": "~/models",
    "LlamaServerBinary": "llama-server",
    "OpenBrowserOnStart": true,
    "HealthPollIntervalSeconds": 15
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
